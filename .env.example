# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_DB=moviedb

# NextAuth
AUTH_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_BASE64_32

# App URL (used for NextAuth callbacks)
# For local: http://localhost:3000
# For server: http://86.48.3.217:3000
APP_URL=http://86.48.3.217:3000

# Admin Account (for seeding)
ADMIN_EMAIL=admin@movietickets.com
ADMIN_PASSWORD=CHANGE_ME_SET_STRONG_PASSWORD

# Admin Portal Secret (required for /auth/portal/admin access)
# Generate with: openssl rand -hex 32
ADMIN_PORTAL_SECRET=CHANGE_ME_GENERATE_SECRET
