generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  emailVerified  DateTime?       @map("email_verified")
  name           String?
  password       String?
  image          String?
  phone          String?
  role           Role            @default(USER)
  membershipTier MembershipTier  @default(NONE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  bookings       Booking[]
  reviews        Review[]
  watchlist      Watchlist[]
  accounts       Account[]
  adminAuditLogs AdminAuditLog[]
  sessions       Session[]

  @@map("users")
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  timestamp DateTime @default(now())
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@map("admin_audit_logs")
}

model Movie {
  id          String       @id @default(uuid())
  title       String
  slug        String       @unique
  description String?
  releaseDate DateTime?
  duration    Int?
  rating      Decimal?     @db.Decimal(2, 1)
  posterUrl   String?
  backdropUrl String?
  language    String       @default("en")
  status      MovieStatus  @default(RELEASED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  cast        CastMember[]
  reviews     Review[]
  showtimes   Showtime[]
  watchlists  Watchlist[]
  genres      Genre[]      @relation("GenreToMovie")
}

model Genre {
  id     String  @id @default(uuid())
  name   String  @unique
  slug   String  @unique
  movies Movie[] @relation("GenreToMovie")
}

model Person {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  birthDate   DateTime?
  photoUrl    String?
  biography   String?
  nationality String?
  cast        CastMember[]
}

model CastMember {
  id            String   @id @default(uuid())
  movieId       String
  personId      String
  role          CastRole
  characterName String?
  movie         Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person        Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([movieId, personId, role, characterName])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  content   String?
  movieId   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  watched   Boolean  @default(false)
  createdAt DateTime @default(now())
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model Hall {
  id          String     @id @default(uuid())
  name        String
  capacity    Int
  hallType    HallType   @default(STANDARD)
  screenType  ScreenType @default(STANDARD_2D)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  rows        Int        @default(8)
  columns     Int        @default(10)
  isPublished Boolean    @default(false)
  publishedAt DateTime?
  version     Int        @default(1)
  rowConfigs  Json?      @map("row_configs")
  updatedAt   DateTime   @default(now()) @updatedAt
  seats       Seat[]
  showtimes   Showtime[]
}

model Showtime {
  id                String         @id @default(uuid())
  movieId           String
  hallId            String
  startTime         DateTime
  endTime           DateTime
  basePrice         Decimal        @db.Decimal(10, 2)
  isWeekend         Boolean        @default(false)
  weekendMultiplier Decimal        @default(1.3)
  vipMultiplier     Decimal        @default(1.5)
  twinseatMultiplier Decimal       @default(1.5)
  status            ShowtimeStatus @default(ACTIVE)
  createdAt         DateTime       @default(now())
  bookings          Booking[]
  hall              Hall           @relation(fields: [hallId], references: [id])
  movie             Movie          @relation(fields: [movieId], references: [id])
  tickets           Ticket[]

  @@index([startTime])
  @@index([movieId])
}

model Seat {
  id           String     @id @default(uuid())
  hallId       String
  row          String
  number       Int
  seatType     SeatType   @default(REGULAR)
  isActive     Boolean    @default(true)
  column       Int        @default(0)
  seatNumber   Int?
  status       SeatStatus @default(AVAILABLE)
  hall         Hall       @relation(fields: [hallId], references: [id])
  tickets      Ticket[]

  @@unique([hallId, row, column])
  @@unique([hallId, row, number])
  @@index([hallId, status])
}

model Booking {
  id            String        @id @default(uuid())
  userId        String
  showtimeId    String
  subtotal      Decimal       @db.Decimal(10, 2)
  totalDiscount Decimal       @db.Decimal(10, 2)
  finalAmount   Decimal       @db.Decimal(10, 2)
  bookingStatus BookingStatus @default(PENDING)
  isScanned     Boolean       @default(false)
  isRated       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  showtime      Showtime      @relation(fields: [showtimeId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  payment       Payment?
  tickets       Ticket[]

  @@index([userId])
}

model Ticket {
  id             String       @id @default(uuid())
  bookingId      String
  showtimeId     String
  seatId         String
  ticketType     TicketType   @default(ADULT)
  originalPrice  Decimal      @db.Decimal(10, 2)
  discountAmount Decimal      @db.Decimal(10, 2)
  finalPrice     Decimal      @db.Decimal(10, 2)
  status         TicketStatus @default(RESERVED)
  createdAt      DateTime     @default(now())
  booking        Booking      @relation(fields: [bookingId], references: [id])
  seat           Seat         @relation(fields: [seatId], references: [id])
  showtime       Showtime     @relation(fields: [showtimeId], references: [id])

  @@unique([showtimeId, seatId])
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

enum Role {
  USER
  ADMIN
  MANAGER
}

enum MembershipTier {
  NONE
  MEMBER
}

enum MovieStatus {
  ANNOUNCED
  POST_PRODUCTION
  RELEASED
  CANCELLED
}

enum HallType {
  Regular
  STANDARD
  VIP
}

enum ScreenType {
  STANDARD_2D
  THREE_D
  SCREENX
}

enum ShowtimeStatus {
  ACTIVE
  CANCELLED
  SOLD_OUT
  COMPLETED
}

enum CastRole {
  ACTOR
  DIRECTOR
  WRITER
  PRODUCER
}

enum SeatType {
  REGULAR
  VIP
  TWINSEAT
}

enum SeatStatus {
  AVAILABLE
  SELECTED
  BOOKED
  RESERVED
  INACTIVE
  BLOCKED
}

enum TicketType {
  ADULT
  CHILD
  STUDENT
  SENIOR
}

enum TicketStatus {
  RESERVED
  CONFIRMED
  CANCELLED
  USED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
  MOBILE_WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
